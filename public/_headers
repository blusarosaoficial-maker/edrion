# index.html — NUNCA cachear, sempre revalidar
/
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache

/index.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache

# Assets com hash — cachear agressivamente (1 ano)
/assets/*
  Cache-Control: public, max-age=31536000, immutable
